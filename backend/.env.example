# ─── Server Configuration ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# ─── CORS Configuration ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Must include portal, cashier-app,
# admin-app, and ecom-backend origins.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5005

# ─── PostgreSQL (Prisma) ────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/storeveu_pos"

# ─── Authentication ─────────────────────────────────────────────────────────
# IMPORTANT: Must be the same value in ecom-backend/.env for JWT sharing
JWT_SECRET=your_jwt_secret_key_here

# ─── E-commerce Sync (Optional) ────────────────────────────────────────────
# URL of the ecom-backend for HTTP fallback sync (when Redis is not available).
# Products auto-sync to ecom on every create/update/delete.
ECOM_BACKEND_URL=http://localhost:5005

# ─── Redis (Optional) ──────────────────────────────────────────────────────
# Used for BullMQ product sync queue. If not set, HTTP fallback is used.
REDIS_URL=redis://127.0.0.1:6379

# ─── External API Integrations ──────────────────────────────────────────────
# OpenAI API (GPT-4o-mini for invoice text enrichment)
OPENAI_API_KEY=sk-proj-...

# Azure Document Intelligence (primary invoice OCR)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ─── Frontend URLs (used in emails for links) ──────────────────────────────
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5175

# ─── Email / SMTP ──────────────────────────────────────────────────────────
# Used for: password reset, signup notifications, user approve/reject/suspend,
# contact form confirmations, support ticket notifications.
# If not configured, emails are skipped but features still work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@storeveu.com
SUPPORT_EMAIL=support@storeveu.com

# ─── POS Connectivity ──────────────────────────────────────────────────────
POS_WRITE_DISABLED=false
