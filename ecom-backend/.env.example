# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5005
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Must include the portal (for management API) and storefront (for public API)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ─── E-commerce Database (separate from POS) ────────────────────────────────
# Create this database: CREATE DATABASE storeveu_ecom;
# Then run: cd ecom-backend && npx prisma db push
DATABASE_URL="postgresql://user:password@localhost:5432/storeveu_ecom"

# ─── POS Backend ────────────────────────────────────────────────────────────
# Used for: stock checks at checkout, full product sync
POS_BACKEND_URL=http://localhost:5000

# ─── Authentication ─────────────────────────────────────────────────────────
# IMPORTANT: Must be the same value as backend/.env JWT_SECRET
JWT_SECRET=your_jwt_secret_key_here

# ─── Redis (Optional) ──────────────────────────────────────────────────────
# Used for BullMQ sync queue + inventory cache. If not available,
# HTTP fallback is used for sync and cache is disabled.
REDIS_URL=redis://127.0.0.1:6379

# ─── Storefront (for ISR revalidation) ──────────────────────────────────────
STOREFRONT_URL=http://localhost:3000
REVALIDATE_SECRET=any_random_secret_string

# ─── Cloudflare for SaaS (Custom Domains — Production Only) ─────────────────
# Required for automatic SSL on custom domains.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# ─── Email / SMTP ───────────────────────────────────────────────────────────
# Used for: contact form notifications, order confirmations, status updates.
# If not configured, emails are skipped silently.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@storeveu.com
SUPPORT_EMAIL=support@storeveu.com
