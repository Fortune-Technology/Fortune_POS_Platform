{
  "name": "@storeveu/types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for the Storeveu POS platform — backend, admin-app, portal, storefront, cashier-app, ecom-backend.",
  "private": true,
  "type": "module",
  "types": "src/index.ts",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
