# ─── E-commerce API (server-side — used in getServerSideProps) ───────────────
ECOM_API_URL=http://localhost:5005/api

# ─── E-commerce API (client-side — used in browser fetch calls) ──────────────
NEXT_PUBLIC_ECOM_API_URL=http://localhost:5005/api

# ─── E-commerce Backend Base URL (for image URLs) ───────────────────────────
NEXT_PUBLIC_ECOM_URL=http://localhost:5005

# ─── ISR Revalidation Secret ────────────────────────────────────────────────
# Must match ecom-backend REVALIDATE_SECRET
REVALIDATE_SECRET=any_random_secret_string

# ─── Default Store Slug (Optional) ──────────────────────────────────────────
# If set, this store loads when no ?store= param and no hostname match.
# If not set, the store discovery page is shown.
# DEFAULT_STORE_SLUG=
